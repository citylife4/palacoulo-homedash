# EcoPi OS - Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. .env will be automatically ignored by git (in .gitignore)
# 4. Never commit .env to version control!

# Database Configuration
DB_PATH=/data/telemetry.db

# Shelly Device IP Addresses
# Replace with YOUR actual device IPs on your network
SHELLY_SOLAR_IP=192.168.188.25       # IP of solar inverter (Shelly)
SHELLY_HOUSE_IP=192.168.188.5        # IP of house meter (Shelly)

# System Configuration
TZ=Europe/Lisbon                      # Timezone for logging and timestamps
DEBUG=False                           # Flask debug mode (False for production)
HOST=0.0.0.0                         # Listen address
PORT=8000                            # Listen port
